{
  "name": "@akoserwal/go-emitter",
  "version": "1.0.2",
  "description": "Clean, understandable Go code generator from TypeSpec definitions",
  "main": "dist/core/emitter.js",
  "bin": {
    "go-emitter": "./dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "config/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "npm run build && jest",
    "test:unit": "npm run build && jest --testPathPattern=test/unit",
    "test:integration": "npm run build && jest --testPathPattern=test/integration",
    "test:coverage": "npm run build && jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts --fix",
    "lint:check": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint:check && npm run format:check && npm run type-check",
    "prepublishOnly": "npm run quality && npm run build && npm run test",
    "clean": "rm -rf dist tmp",
    "clean-all": "npm run clean && rm -rf node_modules"
  },
  "keywords": [
    "typespec",
    "go",
    "golang",
    "codegen",
    "code-generation",
    "api",
    "rest",
    "http",
    "client",
    "sdk"
  ],
  "author": "TypeSpec Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/typespec-community/typespec-go.git"
  },
  "bugs": {
    "url": "https://github.com/typespec-community/typespec-go/issues"
  },
  "homepage": "https://github.com/typespec-community/typespec-go#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "commander": "^9.4.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^30.3.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^4.9.0"
  },
  "peerDependencies": {
    "@typespec/compiler": ">=0.40.0"
  }
}
